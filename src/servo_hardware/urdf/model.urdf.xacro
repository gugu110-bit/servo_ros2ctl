<?xml version="1.0"?>
<robot name="servo" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>
    <material name="orange">
        <color rgba="1 0.5 0 1"/>
    </material>
    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material> 

    <link name="base_link">
    </link>
        
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </joint>

    <link name="chassis_link">
        <visual>
            <geometry>
                <cylinder radius="0.3" length="0.1"/> 
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.3" length="0.1"/>
            </geometry>
        </collision>
    </link>
    
    <joint name="pan_joint" type="revolute">
        <parent link="chassis_link"/>
        <child link="pan_link"/>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="1" velocity="3.14" lower="0" upper="3.14"/> 
    </joint>

    <link name="pan_link">
        <visual>
            <geometry>
                <box size="0.1 0.4 0.3"/> 
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.4 0.3"/> 
            </geometry>
        </collision >
    </link>

    <joint name="tilt_joint" type="revolute">
        <parent link="pan_link"/>
        <child link="tilt_link"/>
        <origin xyz="0 0 0.2" rpy="0 -1.57 3.14"/>
        <axis xyz="0 1 0"/>
        <limit effort="1" velocity="3.14" lower="0" upper="3.14"/>
    </joint>

    <link name="tilt_link">
        <visual>
            <geometry>
                <box size="0.4 0.4 0.1"/> 
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.4 0.4 0.1"/> 
            </geometry>
        </collision >
    </link>
</robot>